{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash scripts/vercel_build.sh",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/music-api/:path*",
      "destination": "https://elitejiosaavn-api.vercel.app/:path*"
    },
    {
      "source": "/aurex-api/:path*",
      "destination": "/api/aurex/:path*"
    },
    {
      "source": "/artwork-api/:path*",
      "destination": "https://elite-music-api.vercel.app/:path*"
    },
    { "source": "/home", "destination": "/index.html" },
    { "source": "/search", "destination": "/index.html" },
    { "source": "/room", "destination": "/index.html" },
    { "source": "/room/:id", "destination": "/index.html" },
    { "source": "/library", "destination": "/index.html" },
    { "source": "/library/playlist/:id", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/auth", "destination": "/index.html" },
    { "source": "/auth/recovery", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/player", "destination": "/index.html" },
    { "source": "/album/:id", "destination": "/index.html" },
    { "source": "/playlist/:id", "destination": "/index.html" },
    { "source": "/artist/:id", "destination": "/index.html" },
    { "source": "/discovery/:kind/:id", "destination": "/index.html" },
    { "source": "/show/:id", "destination": "/index.html" },
    { "source": "/song/:id", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' https://www.gstatic.com 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data: blob:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https: wss:; media-src 'self' https: data: blob:; worker-src 'self' blob:; manifest-src 'self'; form-action 'self'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), ambient-light-sensor=(), autoplay=(self), camera=(), display-capture=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(self), publickey-credentials-get=(), usb=(), xr-spatial-tracking=()"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "off"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        }
      ]
    }
  ]
}
